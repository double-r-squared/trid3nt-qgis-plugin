# TRID3NT OpenRouter preset (NATE 2026-07-19 model extensibility).
# To prove the OpenRouter path with ZERO code: copy the 5 vars below into
# .env.local (replacing the local-ollama GRACE2_OPENAI_* lines), paste your
# key, then re-run scripts/start_agent.sh. Switch back by restoring the ollama
# lines. Changing MODEL alone (same provider) will be live per-turn once the
# plugin model picker ships; changing PROVIDER needs this restart.

MODEL_PROVIDER=openai
GRACE2_OPENAI_BASE_URL=https://openrouter.ai/api/v1
GRACE2_OPENAI_API_KEY=sk-or-REPLACE-WITH-YOUR-OPENROUTER-KEY
# Pick a TOOL-CAPABLE model (the agent is tool-heavy; many :free models ignore
# tools and narrate fake answers). Known-good: deepseek/deepseek-chat,
# meta-llama/llama-3.3-70b-instruct, qwen/qwen-2.5-72b-instruct, mistralai/*.
# Free variants carry a :free suffix (rate-limited).
GRACE2_OPENAI_MODEL=deepseek/deepseek-chat
# OpenRouter has no /api/show, so set the context window explicitly or the
# clip guard false-trips at the 16384 default. Match your model (e.g. 65536).
GRACE2_OPENAI_NUM_CTX=65536

# Optional OpenRouter app attribution (harmless elsewhere):
# GRACE2_OPENAI_HTTP_REFERER=https://trid3nt.local
# GRACE2_OPENAI_X_TITLE=TRID3NT
