      "default": null,
      "title": "Started At"
    },
    "status": {
      "enum": [
        "pending",
        "running",
        "complete",
        "failed",
        "cancelled"
      ],
      "title": "Status",
      "type": "string"
    },
    "user_spatial_inputs": {
      "items": {
        "$ref": "#/$defs/UserSpatialInput"
      },
      "title": "User Spatial Inputs",
      "type": "array"
    },
    "workflow_name": {
      "title": "Workflow Name",
      "type": "string"
    }
  },
  "required": [
    "_id",
    "project_id",
    "session_id",
    "status",
    "run_type",
    "hazard_type",
    "workflow_name",
    "bbox"
