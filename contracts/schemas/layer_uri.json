{
  "$defs": {
    "TemporalConfig": {
      "additionalProperties": false,
      "description": "WMS-T temporal config for a time-varying layer.",
      "properties": {
        "end": {
          "format": "date-time",
          "title": "End",
          "type": "string"
        },
        "start": {
          "format": "date-time",
          "title": "Start",
          "type": "string"
        },
        "step_seconds": {
          "exclusiveMinimum": 0,
          "title": "Step Seconds",
          "type": "integer"
        }
      },
      "required": [
        "start",
        "end",
        "step_seconds"
      ],
      "title": "TemporalConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Returned by ``postprocess_flood`` (one per output layer).\n\nAligned field-for-field with ``map-command load-layer`` args and with\n``ResultLayer`` so postprocess output maps onto the visualization seam with\nno translation. ``uri`` is a COG (raster) or FlatGeobuf/GeoParquet (vector).\n\n``bbox`` is optional (job-0068): when present the pipeline emitter emits a\n``map-command(zoom-to)`` after ``add_loaded_layer`` so the client camera\nflies to the layer's geographic extent. Format: ``(min_lon, min_lat,\nmax_lon, max_lat)`` in EPSG:4326.",
  "properties": {
    "bbox": {
      "anyOf": [
        {
          "maxItems": 4,
          "minItems": 4,
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ],
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Bbox"
    },
    "layer_id": {
      "title": "Layer Id",
      "type": "string"
    },
    "layer_type": {
      "enum": [
        "raster",
        "vector"
      ],
      "title": "Layer Type",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "role": {
      "default": "primary",
      "enum": [
        "primary",
        "context",
        "input"
      ],
      "title": "Role",
      "type": "string"
    },
    "style_preset": {
      "title": "Style Preset",
      "type": "string"
    },
    "temporal": {
      "anyOf": [
        {
          "$ref": "#/$defs/TemporalConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "units": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Units"
    },
    "uri": {
      "title": "Uri",
      "type": "string"
    }
  },
  "required": [
    "layer_id",
    "name",
    "layer_type",
    "uri",
    "style_preset"
  ],
  "title": "LayerURI",
  "type": "object"
}
