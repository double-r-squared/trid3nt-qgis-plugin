    "ResultLayer": {
      "additionalProperties": false,
      "description": "A renderable result layer.\n\nField-for-field alignable with ``map-command load-layer`` args\n(``layer_id``, ``style_preset``, ``temporal``) so the UI renders without\ntranslation. Output formats are fixed by FR-CE-4/FR-QS-3: rasters COG,\nvectors FlatGeobuf/GeoParquet. ``LayerURI`` (execution.py) is the producer\nshape that maps onto this.\n\n``legend`` mirrors ``LayerURI.legend`` -- the DATA-DRIVEN render key (see\n``execution.LegendKey``): the colormap is the semantic per-variable choice,\nthe range is the REAL data range. Additive + optional -- ``None`` means\nlegacy ``style_preset`` rendering, so layers without a legend render exactly\nas before.",
      "properties": {
        "layer_id": {
          "title": "Layer Id",
          "type": "string"
        },
        "layer_type": {
          "enum": [
            "raster",
            "vector"
          ],
          "title": "Layer Type",
          "type": "string"
        },
        "legend": {
          "anyOf": [
            {
              "$ref": "#/$defs/LegendKey"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "role": {
          "enum": [
            "primary",
            "context",
            "input"
          ],
          "title": "Role",
          "type": "string"
        },
        "style_preset": {
          "title": "Style Preset",
          "type": "string"
        },
        "temporal": {
          "anyOf": [
            {
              "$ref": "#/$defs/TemporalConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "units": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Units"
        },
        "uri": {
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "layer_id",
        "name",
        "layer_type",
        "uri",
        "style_preset",
        "role"
      ],
      "title": "ResultLayer",
      "type": "object"
    },
