    "groundwater": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Groundwater"
    },
    "hazard_type": {
      "enum": [
        "flood",
        "groundwater",
        "wildfire",
        "seismic",
        "spill"
      ],
      "title": "Hazard Type",
      "type": "string"
    },
    "layers": {
      "items": {
        "$ref": "#/$defs/ResultLayer"
      },
      "title": "Layers",
      "type": "array"
    },
    "metrics": {
      "$ref": "#/$defs/BaseMetrics"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "schema_version": {
      "const": "v1",
      "default": "v1",
      "title": "Schema Version",
      "type": "string"
    },
    "seismic": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Seismic"
    },
    "session_id": {
      "title": "Session Id",
      "type": "string"
    },
    "solver_run_ids": {
      "items": {
        "type": "string"
      },
      "title": "Solver Run Ids",
