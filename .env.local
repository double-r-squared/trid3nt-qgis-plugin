MODEL_PROVIDER=openai
GRACE2_OPENAI_BASE_URL=http://127.0.0.1:11434/v1
GRACE2_OPENAI_MODEL=qwen3:8b-16k
AWS_ENDPOINT_URL=http://127.0.0.1:9000
AWS_ACCESS_KEY_ID=trid3nt
AWS_SECRET_ACCESS_KEY=trid3nt-local-dev
AWS_REGION=us-east-1
GRACE2_RUNS_BUCKET=trid3nt-runs
GRACE2_CACHE_BUCKET=trid3nt-cache
GRACE2_TILE_SERVER_BASE=http://127.0.0.1:8080
GRACE2_SOLVER_BACKEND=local-docker
GRACE2_SFINCS_IMAGE=deltares/sfincs-cpu:sfincs-v2.3.3
GRACE2_RUNS_DIR=/home/nate/Documents/trid3nt-local/data/runs
GRACE2_MF6_BIN=/home/nate/Documents/trid3nt-local/bin/mf6
GRACE2_AGENT_HOST=0.0.0.0
GRACE2_DEV_PERSISTENCE_DIR=/home/nate/Documents/trid3nt-local/data/persistence
GRACE2_OPENAI_API_KEY=not-needed
AUTH_REQUIRED=false
# Tool retrieval: limit tool context for small-model (3b/7b) inference
# enforce = pick top-K tools per query; keeps context << 4096 tokens
GRACE2_TOOL_RETRIEVAL=enforce
GRACE2_TOOL_RETRIEVAL_K=8
GRACE2_OPENAI_EXTRA_SYSTEM=/no_think
GRACE2_MODFLOW_LOCAL=1
GRACE2_OQ_BIN=/home/nate/Documents/trid3nt-local/venvs/agent/bin/oq
GRACE2_GEOCLAW_IMAGE=trid3nt-local/geoclaw:latest
GRACE2_SWAN_IMAGE=trid3nt-local/swan:latest
GRACE2_CATALOG_YAML=/home/nate/Documents/trid3nt-local/vendor/public_data_source_catalog.yaml
# 2026-07-06 (NATE): arm global sync-tool offload locally -- an abandoned sweep
# prompt's heavy fetch chain (usace_nsi + river geometry) ran ON the asyncio
# loop and starved new WS handshakes; global mode was proven safe on cloud.
GRACE2_SYNC_TOOL_OFFLOAD=global
GRACE2_TELEMETRY_PATH=/home/nate/Documents/trid3nt-local/data/telemetry/tool_calls.jsonl
GRACE2_LESSONS=on
