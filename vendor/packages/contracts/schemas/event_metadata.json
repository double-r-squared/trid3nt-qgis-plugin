      "type": "object"
    },
    "EventLocation": {
      "additionalProperties": false,
      "description": "Event location. At least one of ``bbox`` or ``place_name`` is required.",
      "properties": {
        "admin_unit": {
          "anyOf": [
            {
              "$ref": "#/$defs/AdminUnit"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "bbox": {
          "anyOf": [
            {
              "maxItems": 4,
              "minItems": 4,
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                },
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bbox"
        },
        "geocoded": {
          "default": false,
          "title": "Geocoded",
          "type": "boolean"
        },
        "granularity": {
          "anyOf": [
            {
              "enum": [
                "country",
                "region",
                "state",
                "city",
                "facility",
                "bbox"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Granularity"
        },
        "place_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Place Name"
        },
        "precision_class": {
          "anyOf": [
            {
              "enum": [
                "point_known",
                "polygon_known",
                "bbox_sufficient",
                "imprecise",
                "ambiguous"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Precision Class"
        }
      },
      "title": "EventLocation",
      "type": "object"
    },
