        },
        "locality": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Locality"
        },
        "region": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region"
        }
      },
      "title": "AdminUnit",
      "type": "object"
    },
    "AtmosphericRiverIntensity": {
      "additionalProperties": false,
      "properties": {
        "ar_category": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClaimSet"
            },
            {
              "type": "null"
            }
          ],
          "default": null
