  "additionalProperties": false,
  "description": "Structured representation of a real-world hazard event (Appendix C.2).",
  "properties": {
    "canonical_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Canonical Id"
    },
    "canonical_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Canonical Name"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "embedding": {
      "anyOf": [
        {
          "items": {
            "type": "number"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Embedding"
    },
    "embedding_model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Embedding Model"
    },
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "enum": [
        "hurricane",
        "tropical_storm",
        "atmospheric_river",
        "intense_rainfall",
        "dam_failure",
        "levee_failure",
        "storm_surge",
        "river_flood",
        "flash_flood",
        "other"
      ],
      "title": "Event Type",
      "type": "string"
    },
    "extracted_at": {
      "format": "date-time",
      "title": "Extracted At",
      "type": "string"
    },
    "extractor_version": {
      "title": "Extractor Version",
      "type": "string"
    },
    "intensity": {
      "$ref": "#/$defs/IntensityIndicators"
    },
    "location": {
      "$ref": "#/$defs/EventLocation"
    },
    "provenance": {
      "$ref": "#/$defs/EventProvenance"
    },
    "schema_version": {
      "const": "v1",
      "default": "v1",
      "title": "Schema Version",
      "type": "string"
    },
    "time_classification": {
      "enum": [
        "past",
        "ongoing",
        "forecast"
      ],
      "title": "Time Classification",
      "type": "string"
    },
    "time_range": {
      "$ref": "#/$defs/TimeRange"
    }
  },
  "required": [
    "event_id",
    "event_type",
    "confidence",
    "location",
    "time_range",
    "time_classification",
    "intensity",
    "provenance",
    "extracted_at",
    "extractor_version"
  ],
  "title": "EventMetadata",
  "type": "object"
}
