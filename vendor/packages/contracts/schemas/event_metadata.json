    "ClaimSet": {
      "additionalProperties": false,
      "description": "A set of numerical claims for one quantity across sources, with consensus.\n\n``consensus_value`` is the narrated number (invariant 7). Contributing\n``claims`` stay drillable. Populated by ``aggregate_claims_across_sources``\n(engine-owned); ``schema`` owns this shape.",
      "properties": {
        "claims": {
          "items": {
            "$ref": "#/$defs/NumericClaim"
          },
          "title": "Claims",
          "type": "array"
        },
        "consensus_confidence": {
          "anyOf": [
            {
              "enum": [
                "high",
                "medium",
                "low"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consensus Confidence"
        },
        "consensus_method": {
          "anyOf": [
            {
              "enum": [
                "single_source",
                "median",
                "authority_weighted",
                "latest_authoritative",
                "agent_synthesized"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consensus Method"
        },
        "consensus_unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consensus Unit"
        },
        "consensus_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Consensus Value"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        }
      },
      "title": "ClaimSet",
      "type": "object"
    },
