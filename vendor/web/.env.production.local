# GRACE-2 web — CloudFront HTTPS + Cognito sign-in (optional). job-0299.
VITE_GRACE2_PUBLIC_BASE=d125yfbyjrpbre.cloudfront.net
VITE_GRACE2_WS_URL=wss://d125yfbyjrpbre.cloudfront.net/ws
# wave3: agent auto-stop wake endpoint (API-Gateway, a SEPARATE origin from CloudFront)
# GET reports box state (asleep detection); POST wakes (StartInstances).
VITE_GRACE2_WAKE_URL=https://9ib093sis6.execute-api.us-west-2.amazonaws.com/wake
# sleep/wake STAGE 2: case-view signer endpoint (same API-Gateway, SEPARATE origin).
# GET ?case_id=<id> -> pre-signed S3 GET to the case-view JSON snapshot (cold-load
# paints a Case with the agent box asleep). 404 -> no snapshot yet.
VITE_GRACE2_CASE_VIEW_URL=https://9ib093sis6.execute-api.us-west-2.amazonaws.com/case-view-url
# sleep/wake STAGE 2: case-list endpoint (same API-Gateway, SEPARATE origin).
# GET -> {envelope_type:"case-list", cases:[...]} so the Cases rail renders COLD
# with the agent box asleep (single GET; sibling of the case-view signer).
VITE_GRACE2_CASE_LIST_URL=https://9ib093sis6.execute-api.us-west-2.amazonaws.com/case-list
# data export: case-export endpoint (same API-Gateway, SEPARATE origin). GET
# ?case_id=<id> -> {url, size_bytes, layer_count} (pre-signed S3 GET to a
# packaged data archive); the web triggers a browser download. Signed-in only.
VITE_GRACE2_CASE_EXPORT_URL=https://9ib093sis6.execute-api.us-west-2.amazonaws.com/case-export-url
# Cognito Hosted UI (email/password). Sign-in AVAILABLE; anon still works (AUTH_REQUIRED off).
VITE_COGNITO_USER_POOL_ID=us-west-2_mIpKrr727
VITE_COGNITO_CLIENT_ID=43ovkrtt97oh6gsnl006aecera
VITE_COGNITO_DOMAIN=grace2-auth.auth.us-west-2.amazoncognito.com
VITE_COGNITO_REGION=us-west-2
VITE_COGNITO_REDIRECT_URI=https://d125yfbyjrpbre.cloudfront.net/
