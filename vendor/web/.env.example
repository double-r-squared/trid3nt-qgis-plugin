# GRACE-2 web — Vite environment variables.
#
# Copy to `.env.local` (gitignored by Vite) and fill in real values. ALL VITE_*
# vars are exposed to the browser bundle — the Cognito client config below are
# "public" client values and are SAFE to ship to clients (the SPA app client is
# a PUBLIC client with no secret; PKCE protects the code exchange, and the agent
# enforces auth by verifying the ID token against the Cognito JWKS).
#
# When VITE_COGNITO_USER_POOL_ID, VITE_COGNITO_CLIENT_ID, or VITE_COGNITO_DOMAIN
# are empty, the web client runs in DISABLED / anonymous-only mode: no hosted
# sign-in is available, the "Continue without saving" path works against the
# agent's anonymous fallback (no auth-token envelope is sent on connect), and
# the AuthGuard is a transparent pass-through. This is the default so the live
# demo is unaffected until the orchestrator injects the Cognito env and rebuilds.

# --- WebSocket endpoint (existing, M1 vintage) --------------------------- #
# Default ws://localhost:8765 (the local agent service from job-0015).
VITE_GRACE2_WS_URL=ws://localhost:8765

# --- Single public origin (CloudFront edge; optional) -------------------- #
# When set, the web derives wss://<base>/ws + https://<base> + (with the two
# endpoints below unset) <base>/wake and <base>/case-view-url. Unset = dev/LAN
# defaults (localhost ports); wake + cold-load are disabled.
VITE_GRACE2_PUBLIC_BASE=

# --- Agent auto-stop / sleep-wake (STAGE 2) ------------------------------ #
# The API-Gateway endpoint fronting the wake Lambda (a SEPARATE origin from the
# CloudFront edge). GET reports the box state WITHOUT waking it (asleep
# detection); POST WAKES (StartInstances). Unset = wake disabled (dev/LAN).
VITE_GRACE2_WAKE_URL=
# The API-Gateway endpoint fronting the case-view signer Lambda. GET
# ?case_id=<id> -> a pre-signed S3 GET to the case-view JSON snapshot so a Case
# paints COLD with the agent box asleep. Unset = cold-load disabled (dev/LAN).
VITE_GRACE2_CASE_VIEW_URL=
# The API-Gateway endpoint fronting the case-list Lambda. GET -> the user's
# {envelope_type:"case-list", cases:[...]} so the Cases rail renders COLD with
# the agent box asleep (single GET). Unset = cold-load disabled (dev/LAN).
VITE_GRACE2_CASE_LIST_URL=
# The API-Gateway endpoint fronting the case-export Lambda. GET ?case_id=<id> ->
# {url, size_bytes, layer_count} where `url` is a pre-signed S3 GET to a packaged
# data archive; the web triggers a browser download. Requires a signed-in user.
# Unset = export disabled (the Export button is hidden; dev/LAN).
VITE_GRACE2_CASE_EXPORT_URL=

# --- AWS Cognito Hosted UI (OIDC code flow + PKCE; SRS Appendix H) ------- #
# Required to enable hosted email/password sign-in. All THREE of POOL_ID,
# CLIENT_ID, and DOMAIN must be set; missing any one falls back to disabled /
# anonymous-only mode.
#
# VITE_COGNITO_USER_POOL_ID — the user pool id, e.g. us-west-2_AbCdEf123.
VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID — the SPA app client id (public client, no secret).
VITE_COGNITO_CLIENT_ID=
# VITE_COGNITO_DOMAIN — the Hosted UI domain (host only, no scheme), e.g.
# grace2-auth.auth.us-west-2.amazoncognito.com
VITE_COGNITO_DOMAIN=
# VITE_COGNITO_REGION — AWS region of the pool. Defaults to us-west-2 if unset.
VITE_COGNITO_REGION=us-west-2
# VITE_COGNITO_REDIRECT_URI — must EXACTLY match a registered Hosted UI callback
# URL (scheme + host + path, including trailing slash). Defaults to the app
# origin root (window.location.origin + "/") if unset. Set explicitly for the
# static S3 site, e.g. http://grace2-web.s3-website-us-west-2.amazonaws.com/
VITE_COGNITO_REDIRECT_URI=
